# Stallion Courier backend — environment template
# Production refuses to start without a strong session secret, an administrator,
# and explicit CORS origins.
STALLION_ENV=production
STALLION_SESSION_SECRET=change-me-openssl-rand-hex-32
STALLION_SESSION_TTL_SECONDS=28800
STALLION_CORS_ORIGINS=https://your-site.netlify.app

# Generate each password_hash from backend/ with:
#   python scripts/create_user_hash.py
# Roles: clerk | broker | admin
STALLION_USERS_JSON=[{"username":"admin","name":"Stallion Administrator","role":"admin","password_hash":"pbkdf2_sha256$310000$replace-salt$replace-hash"},{"username":"broker","name":"Licensed Broker","role":"broker","password_hash":"pbkdf2_sha256$310000$replace-salt$replace-hash"}]

# Transactional data store. Defaults to a local SQLite file (backend/data/
# stallion.db) when unset — fine for dev. In production use PostgreSQL:
#   DATABASE_URL=postgresql+psycopg://stallion:<password>@localhost:5432/stallion
# On first start the app imports any existing data/*.json records automatically;
# you can also run it explicitly with `python scripts/migrate_json_to_db.py`.
DATABASE_URL=postgresql+psycopg://stallion:change-me@localhost:5432/stallion

ANTHROPIC_API_KEY=sk-ant-...
