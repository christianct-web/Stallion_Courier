# ─── Stallion API Configuration ──────────────────────────────────────────────

# Required: Claude API key for document extraction and HS search
ANTHROPIC_API_KEY=sk-ant-...

# Required: Path to your ace-backend checkout (for ASYCUDA XML generation)
ACE_BACKEND_PATH=/path/to/ace-backend

# Optional: API key authentication (leave empty to disable auth in local dev)
# When set, all requests must include X-API-Key header with this value.
STALLION_API_KEY=

# Optional: CORS origins (comma-separated). Defaults to "*" if not set.
# In production, restrict to your frontend domain(s).
STALLION_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Broker identity on generated documents (costing PDF, invoices)
# Defaults to Fast Freight Forwarders Ltd if not set.
STALLION_BROKER_FIRM=Fast Freight Forwarders Ltd
STALLION_BROKER_ADDRESS=38 O'Connor Street, Woodbrook, Port of Spain
STALLION_BROKER_PHONE=(868) 628-2255

# Optional: Generated file cleanup TTL in seconds (default: 7 days = 604800)
STALLION_CLEANUP_TTL_SECONDS=604800

# Optional: Supabase (for future migration off JSON file storage)
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...
